# Nginx Port (Standard: 80)
HTTP_PORT=80

# Öffentliche URL der App (für CORS) — mit Schema, ohne Slash am Ende
APP_URL=https://deine-domain.de

# JWT Secret — unbedingt ändern!
JWT_SECRET=change-this-to-a-long-random-secret

# Initialer Admin-Account (wird nur angelegt wenn DB noch leer ist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Administrator

# SMTP (leer lassen = E-Mail deaktiviert)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURITY=starttls
FROM_EMAIL=noreply@example.com
COMPANY_NAME=abat AG
