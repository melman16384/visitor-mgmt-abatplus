PORT=3001
JWT_SECRET=<openssl rand -hex 64>
DB_PATH=/opt/visitor-mgmt-abatplus/backend/data/visitors.db
APP_URL=https://deine-domain.de

# Microsoft SSO (Azure App Registration)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# App-only Verzeichniszugriff (separate Azure-App-Registrierung empfohlen)
# Application Permissions (Admin-Zustimmung erforderlich): User.Read.All, Mail.Send
# Wird für Gastgeber-AD-Autocomplete, Admin-Gegencheck und Ankunfts-Mail an Gastgeber genutzt.
AZURE_DIRECTORY_TENANT_ID=
AZURE_DIRECTORY_CLIENT_ID=
AZURE_DIRECTORY_CLIENT_SECRET=

# Absender-Postfach für Gastgeber-Benachrichtigungen (Microsoft Graph sendMail)
NOTIFY_FROM_EMAIL=

# Initialer Admin-Account (nur beim allerersten Start wirksam, danach ignoriert)
# ADMIN_EMAIL=admin@firma.de
# ADMIN_PASSWORD=SicheresPasswort123!
